# ============================================================
# FantaParto — Environment Variables (MODELLO — committare su Git)
# Copia questo file in .env.local e sostituisci i valori reali.
# MAI inserire credenziali reali in questo file.
# ============================================================

# ------------------------------------------------------------
# Supabase — Database (Prisma ORM)
# Pannello Supabase > Project Settings > Database > Connection string
# Usa la modalità "Transaction" (porta 6543) per il client Next.js
# ------------------------------------------------------------
DATABASE_URL=""

# ------------------------------------------------------------
# Supabase — SDK (lato browser e server)
# Pannello Supabase > Project Settings > API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ------------------------------------------------------------
# Upstash Redis — Rate limiting
# Pannello Upstash > Database > REST API
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ------------------------------------------------------------
# Admin — Dashboard /regia-segreta-9832
# Lista di email autorizzate separate da virgola.
# Utenti autenticati NON in questa lista ricevono un 404 finto.
# ------------------------------------------------------------
ADMIN_EMAILS=""
